# Broker config
PORT=4000

# CentreBlock API base URL
CENTREBLOCK_API=https://prod.centreblock.net/api/v1/

# Master key for encrypting secrets in DB
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace_this_with_64_char_hex_string

# Debug mode - logs every request/response to console
DEBUG=true
